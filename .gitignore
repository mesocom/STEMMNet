# Ignore Particle/Arduino build artifacts
*.bin
*.elf
*.hex
*.map
*.lst

# Allow .bin files only if they are placed in a 'bins' subdirectory
!**/bins/*.bin

# Particle Workbench / VS Code files
.vscode/
.history/
target/
lib/
!v2/*/lib/

# OS/IDE junk
.DS_Store
Thumbs.db
*.swp
*~

# Environment files
.env
.env.*

# Standard project ignore
node_modules/
dist/
build/
